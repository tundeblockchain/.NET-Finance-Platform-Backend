{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "FinancePlatform": "Server=localhost;Database=FinancePlatform;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Persistence": {
    "Provider": "InMemory"
  },
  "Broker": {
    "WorkerInstanceId": "local-worker-1",
    "LeaseDurationSeconds": 30,
    "SeedSampleWorkflowOnStartup": true,
    "Retry": {
      "BaseDelayMilliseconds": 500,
      "MaxDelayMilliseconds": 30000,
      "JitterFactor": 0.2
    },
    "Queues": [
      {
        "Name": "Cash",
        "MaxConcurrency": 2,
        "PollIntervalMilliseconds": 200
      },
      {
        "Name": "Trading",
        "MaxConcurrency": 2,
        "PollIntervalMilliseconds": 200
      },
      {
        "Name": "Settlement",
        "MaxConcurrency": 1,
        "PollIntervalMilliseconds": 500
      },
      {
        "Name": "Reversal",
        "MaxConcurrency": 1,
        "PollIntervalMilliseconds": 500
      }
    ]
  }
}
