    "Alpaca": {
      "ApiKey": "",
      "ApiSecret": "",
      "Paper": true,
      "TradingBaseUrl": "https://paper-api.alpaca.markets",
      "DataBaseUrl": "https://data.alpaca.markets"
    }
  }
}
