# Copy to backend/.env and fill in values. .env is gitignored.
# Nested config uses double underscores (Brokers:Alpaca:ApiKey → Brokers__Alpaca__ApiKey).

Brokers__Provider=Alpaca
Brokers__Alpaca__ApiKey=
Brokers__Alpaca__ApiSecret=
Brokers__Alpaca__Paper=true

# Optional overrides
# ConnectionStrings__FinancePlatform=Server=localhost;Database=FinancePlatform;Trusted_Connection=True;TrustServerCertificate=True
# Persistence__Provider=SqlServer
